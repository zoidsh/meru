{
  "name": "meru",
  "version": "3.38.4",
  "private": true,
  "description": "Tired of losing your inbox in browser tabs? Meru brings Gmail to your fingertips as a desktop app",
  "author": "Tim Cheung <tim@meru.so>",
  "repository": "zoidsh/meru",
  "workspaces": [
    "packages/*"
  ],
  "main": "build-js/app.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "bun run scripts/build.ts --dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions --fix-dangerously",
    "types": "tsc && bun run --filter='*' --elide-lines=0 types",
    "types:ci": "tsc && bun run --filter='*' types",
    "build:clean-dist": "bun run scripts/clean-dist.ts",
    "build:js": "bun run scripts/build.ts",
    "build:mac": "bun run build:js && bun run build:clean-dist && electron-builder --mac",
    "build:linux": "bun run build:js && bun run build:clean-dist && electron-builder --linux",
    "build:win": "bun run build:js && bun run build:clean-dist && electron-builder --win"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/typed-ipc": "^1.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/inter": "^5.2.5",
    "@ghostery/adblocker": "^2.12.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.90.5",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/trusted-types": "^2.0.7",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "electron-context-menu": "^4.1.0",
    "electron-dl": "^4.0.0",
    "electron-log": "^5.4.0",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.6.2",
    "element-ready": "^7.0.0",
    "fast-xml-parser": "^5.5.7",
    "frimousse": "^0.3.0",
    "is-online": "^12.0.2",
    "lefthook": "^2.1.2",
    "lucide-react": "^0.475.0",
    "meru-api-client": "^2.1.1",
    "node-machine-id": "^1.1.12",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "postcss": "^8.5.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hotkeys-hook": "^5.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rolldown": "^1.0.0-rc.10",
    "select-dom": "^9.3.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "type-fest": "^5.2.0",
    "typescript": "^5.8.3",
    "use-debounce": "^10.0.6",
    "vite": "^8.0.1",
    "vite-plugin-singlefile": "^2.3.2",
    "wouter": "^3.7.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "build": {
    "files": [
      "build-js",
      "static"
    ],
    "appId": "sh.zoid.meru",
    "protocols": {
      "name": "Meru",
      "schemes": [
        "meru",
        "mailto"
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "target": {
        "target": "default",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "extendInfo": {
        "CFBundleIconName": "AppIcon",
        "CFBundleURLSchemes": [
          "meru",
          "mailto"
        ],
        "NSCameraUsageDescription": "Meru needs access to your camera for Google apps like Meet and Chat.",
        "NSMicrophoneUsageDescription": "Meru needs access to your camera for Google apps like Meet and Chat."
      }
    },
    "linux": {
      "icon": "build/icons/",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "synopsis": "The Gmail experience you deserve",
      "description": "Tired of losing your inbox in browser tabs? Meru brings Gmail to your fingertips as a desktop app",
      "category": "Network;Office"
    },
    "win": {
      "verifyUpdateCodeSignature": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "afterPack": "./build/hooks/afterPack.js"
  },
  "patchedDependencies": {
    "electron-context-menu@4.1.0": "patches/electron-context-menu@4.1.0.patch",
    "conf@14.0.0": "patches/conf@14.0.0.patch",
    "sonner@2.0.7": "patches/sonner@2.0.7.patch"
  },
  "productName": "Meru"
}
